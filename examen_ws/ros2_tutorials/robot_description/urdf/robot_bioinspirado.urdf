<?xml version="1.0"?>
<robot name="robot_XY_4DOF">

    <material name="link_color"><color rgba="0.8 0.5 0.2 1"/></material>
    <material name="joint_color"><color rgba="0.1 0.1 0.6 1"/></material>
    <material name="red"><color rgba="1 0 0 1"/></material>

    <link name="base_link">
        <visual>
            <geometry><box size="0.5 0.5 0.2"/></geometry>
            <material name="joint_color"/>
        </visual>
    </link>

    <joint name="q1" type="revolute">
        <parent link="base_link"/>
        <child link="link1"/>
        <origin xyz="0 0 0.1" rpy="0 0 0"/> 
        <axis xyz="0 0 1"/>
        <limit lower="-3.14" upper="3.14" effort="10" velocity="1"/>
    </joint>

    <link name="link1">
        <visual>
            <origin xyz="5 0 0" rpy="0 1.5708 0"/> 
            <geometry><cylinder length="10" radius="0.4"/></geometry>
            <material name="link_color"/>
        </visual>
    </link>

    <joint name="q2" type="revolute">
        <parent link="link1"/>
        <child link="link2"/>
        <origin xyz="10 0 0" rpy="0 0 0"/> 
        <axis xyz="0 0 1"/>
        <limit lower="-3.14" upper="3.14" effort="10" velocity="1"/>
    </joint>

    <link name="link2">
        <visual>
            <origin xyz="3 0 0" rpy="0 1.5708 0"/>
            <geometry><cylinder length="6" radius="0.4"/></geometry>
            <material name="red"/>
        </visual>
    </link>

    <joint name="q3" type="revolute">
        <parent link="link2"/>
        <child link="link3"/>
        <origin xyz="6 0 0" rpy="0 0 0"/> 
        <axis xyz="0 0 1"/>
        <limit lower="-3.14" upper="3.14" effort="10" velocity="1"/>
    </joint>

    <link name="link3">
        <visual>
            <origin xyz="2 0 0" rpy="0 1.5708 0"/>
            <geometry><cylinder length="4" radius="0.4"/></geometry>
            <material name="link_color"/>
        </visual>
    </link>

    <joint name="q4" type="revolute">
        <parent link="link3"/>
        <child link="link4"/>
        <origin xyz="4 0 0" rpy="0 0 0"/> 
        <axis xyz="0 0 1"/>
        <limit lower="-3.14" upper="3.14" effort="10" velocity="1"/>
    </joint>

    <link name="link4">
        <visual>
            <origin xyz="1.5 0 0" rpy="0 1.5708 0"/>
            <geometry><cylinder length="3" radius="0.4"/></geometry>
            <material name="red"/>
        </visual>
    </link>

    <link name="ee_link">
        <visual>
            <geometry><sphere radius="0.6"/></geometry>
            <material name="joint_color"/>
        </visual>
    </link>

    <joint name="tool0" type="fixed">
        <parent link="link4"/>
        <child link="ee_link"/>
        <origin xyz="3 0 0" rpy="0 0 0"/> 
    </joint>

</robot>